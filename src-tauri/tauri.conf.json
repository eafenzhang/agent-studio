{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Agent Studio",
  "version": "1.0.17",
  "identifier": "com.agentstudio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Agent Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src http://127.0.0.1:25808 ws://127.0.0.1:25808; img-src 'self' http://127.0.0.1:25808 data:; font-src 'self'; object-src 'none'; frame-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/eafenzhang/agent-studio/releases/latest/download/latest.json"],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "resources": {
      "resources/aioncore.exe": "."
    }
  }
}
