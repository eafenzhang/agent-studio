{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "Agent Studio",
  "version": "5.1.3",
  "identifier": "com.agentstudio.desktop",
  "build": {
    "frontendDist": "../../agent-studio-react/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Agent Studio",
        "width": 1440,
        "height": 810,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/aioncore",
      "binaries/aionrs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
